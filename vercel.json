{
  "version": 2,
  "functions": {
    "api/index.js": {
      "runtime": "edge",
      "maxDuration": 10
    }
  },
  "builds": [
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "dist/client" } },
    { "src": "api/index.js", "use": "@vercel/edge" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "^/(.*)$", "dest": "/api/index.js" }
  ]
}
