{
  "version": 2,
  "builds": [
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "dist/client" } },
    { "src": "api/index.edge.js", "use": "@vercel/edge" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "^/(.*)$", "dest": "/api/index.edge.js" }
  ]
}
